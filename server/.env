# Environment variables for local development
# NOTE: This file has been sanitized to remove real credentials.
# Do NOT commit real secrets. See `server/.env.example` for placeholders.

# MongoDB connection (use your local or provisioned DB URI)
MONGO_URI=REPLACE_WITH_YOUR_MONGO_URI

# JWT for authentication
JWT_SECRET=REPLACE_WITH_JWT_SECRET

# Email (Nodemailer) - replace with your SMTP credentials or use SendGrid
MAIL_USER=REPLACE_WITH_MAIL_USER
MAIL_PASSWORD=REPLACE_WITH_MAIL_PASSWORD

# SendGrid (optional)
SENDGRID_API_KEY=REPLACE_WITH_SENDGRID_API_KEY
SENDGRID_FROM_EMAIL=REPLACE_WITH_SENDGRID_FROM_EMAIL

# Fast2SMS (optional)
FAST2SMS_API_KEY=REPLACE_WITH_FAST2SMS_API_KEY

# Other application-specific variables
# Example: PORT=3000

# End of sanitized .env
