# Required
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# Optional: use if mongodb+srv DNS lookups fail on your network
# MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1

# Recommended
JWT_SECRET=change-me-to-a-long-random-string

# Optional (only if using OTP/email features)
# Choose provider: gmail (recommended) or resend or sendgrid
EMAIL_PROVIDER=gmail
RESEND_API_KEY=
RESEND_FROM_EMAIL=
MAIL_USER=you@example.com
MAIL_PASSWORD=your-email-app-password
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Optional (use if frontend is on another domain; comma-separated)
# For Vercel single-project deploy, this is usually not required.
# CORS_ORIGIN=https://your-project.vercel.app
