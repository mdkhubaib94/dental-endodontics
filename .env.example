# Root deployment reference for Vercel
# Set these in Vercel Project Settings -> Environment Variables

NODE_ENV=production
MONGO_URI=
JWT_SECRET=

# Optional for cross-domain frontend/backend
# CORS_ORIGIN=https://your-project.vercel.app

# Optional email settings
# Choose provider: gmail (recommended) or resend or sendgrid
# EMAIL_PROVIDER=gmail
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# MAIL_USER=
# MAIL_PASSWORD=
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=

# Optional client runtime override (normally leave empty for same-origin)
# VITE_API_BASE_URL=
